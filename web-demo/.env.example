# Server-side only — set in Vercel as an Environment Variable, NEVER commit a real key.
# A THROWAWAY Braga testnet burner funded at https://braga.hoodi.arkiv.network/faucet/ .
# It signs the Arkiv (Braga) writes locally; it is never sent to the browser.
PRIVATE_KEY=0x...

# Optional: your own Arkiv RPC (defaults to the SDK's Braga RPC).
# ARKIV_RPC_URL=
