# Copy to .env and fill PRIVATE_KEY. `.env` is gitignored — NEVER commit it.

# A THROWAWAY testnet wallet, funded with GLM on the Braga faucet:
#   https://braga.hoodi.arkiv.network/faucet/
# Signs Arkiv writes locally (viem); never leaves your machine. Never a key with real funds.
PRIVATE_KEY=0xYOUR_THROWAWAY_TESTNET_PRIVATE_KEY

# Optional: your own source-chain RPC (else a public keyless pool with rotation is used).
# Per-chain override: <CHAIN>_RPC_URL — e.g. SEPOLIA_RPC_URL, ETHEREUM_RPC_URL, BASE_RPC_URL, BSC_RPC_URL.
# SEPOLIA_RPC_URL=

# Optional: override the Arkiv (Braga) RPC.
# ARKIV_RPC_URL=https://braga.hoodi.arkiv.network/rpc
